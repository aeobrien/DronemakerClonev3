	(text "Rotary Encoders:\n- Each has Channel A/B + push switch\n- Signals to Teensy GPIOs with internal pull-ups\n- Detects rotation direction/speed\n- Push switch provides extra input"
		(exclude_from_sim no)
		(at 92.456 115.824 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
			(justify left)
		)
		(uuid "240937fa-daa2-4a76-8eee-f61318a5cf8c")
	)
	(text "Teensy 4.1_MCU_48PINS_SOCKET\n"
		(exclude_from_sim no)
		(at 330.454 92.964 0)
		(effects
			(font
				(size 1.905 1.905)
				(thickness 0.381)
				(bold yes)
			)
		)
		(uuid "4b07bd0d-e691-44f5-940a-4a8024c30ddf")
	)
	(text "Teensy 4.1 - Microcontroller:\n- Main controller for MIDI system\n- Reads 8 rotary encoders (A/B + push) and 8 RGB buttons\n- Drives RGB LEDs via three 74HC595 shift registers (DATA/CLOCK/LATCH)\n- Provides +3.3V logic, +5V LED power\n- Inputs active-low with internal pull-ups\n\n"
		(exclude_from_sim no)
		(at 240.538 119.634 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
			(justify left)
		)
		(uuid "4dfca677-0adb-4fc8-8806-43a0e8d5afc5")
	)
	(text "RGB Buttons:\n- Each has 1 tactile switch + 3 LEDs (R/G/B)\n- Switches active-low to Teensy\n- LED anodes to +5V, cathodes via 220Ω to shift registers\n- Provides user input and LED feedback"
		(exclude_from_sim no)
		(at 241.046 235.712 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
			(justify left)
		)
		(uuid "6aa048a8-390f-438c-a526-62d299e8d5fb")
	)
	(text "74HC595 Shift Registers - RGB LED Driver:\n- Controls RGB LED cathodes\n- U1: Green, U2: Red, U3: Blue\n- Daisy-chained for 24 outputs via 3 pins\n- Active-low outputs (LOW = LED ON)\n- OE always enabled, MR tied HIGH\n"
		(exclude_from_sim no)
		(at 137.668 231.902 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
			(justify left)
		)
		(uuid "d30f701f-d47c-4065-ae1b-5726048d4e90")
	)
